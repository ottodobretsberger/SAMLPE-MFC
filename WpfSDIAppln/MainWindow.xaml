<Window x:Class="WpfSDIAppln.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfSDIAppln"
        xmlns:views="clr-namespace:WpfSDIAppln.Views"
        xmlns:vm="clr-namespace:WpfSDIAppln.ViewModels"
        mc:Ignorable="d"
        Title="WPF SDI Application" Height="600" Width="900">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewDocumentCommand}"/>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenDocumentCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveDocumentCommand}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PrintCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Data Templates for Views -->
        <DataTemplate x:Key="MainViewTemplate" DataType="{x:Type vm:MainViewViewModel}">
            <views:MainViewControl/>
        </DataTemplate>

        <DataTemplate x:Key="FormViewTemplate" DataType="{x:Type vm:FormViewViewModel}">
            <views:FormViewControl/>
        </DataTemplate>

        <DataTemplate x:Key="EditViewTemplate" DataType="{x:Type vm:EditViewViewModel}">
            <views:EditViewControl/>
        </DataTemplate>

        <!-- DataTemplateSelector -->
        <views:ViewDataTemplateSelector x:Key="ViewTemplateSelector"
                                        MainViewTemplate="{StaticResource MainViewTemplate}"
                                        FormViewTemplate="{StaticResource FormViewTemplate}"
                                        EditViewTemplate="{StaticResource EditViewTemplate}"/>
    </Window.Resources>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewDocumentCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenDocumentCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" Command="{Binding SaveDocumentCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Print..." Command="{Binding PrintCommand}" InputGestureText="Ctrl+P"/>
                <MenuItem Header="Print Pre_view"/>
                <MenuItem Header="Print Set_up..."/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="Cu_t" InputGestureText="Ctrl+X"/>
                <MenuItem Header="_Copy" InputGestureText="Ctrl+C"/>
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Command="{Binding NewDocumentCommand}" ToolTip="New">
                    <Image Source="pack://application:,,,/Resources/New.png" Width="16" Height="16" 
                           RenderOptions.BitmapScalingMode="NearestNeighbor">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsEnabled}" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Button>
                <Button Command="{Binding OpenDocumentCommand}" ToolTip="Open">
                    <TextBlock Text="📂" FontSize="16"/>
                </Button>
                <Button Command="{Binding SaveDocumentCommand}" ToolTip="Save">
                    <TextBlock Text="💾" FontSize="16"/>
                </Button>
                <Separator/>
                <Button Command="{Binding PrintCommand}" ToolTip="Print">
                    <TextBlock Text="🖨" FontSize="16"/>
                </Button>
                <Separator/>
                <TextBlock Text="View:" VerticalAlignment="Center" Margin="5,0"/>
                <ComboBox ItemsSource="{Binding ViewNames}" 
                          SelectedItem="{Binding SelectedViewName}"
                          Width="150"
                          ToolTip="Switch View"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusBarText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="CAPS"/>
                            <Setter Property="Opacity" Value="0.3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CapsLockOn}" Value="True">
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="NUM"/>
                            <Setter Property="Opacity" Value="0.3"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NumLockOn}" Value="True">
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content Area -->
        <Border BorderBrush="LightGray" BorderThickness="1" Margin="5">
            <ContentControl Content="{Binding CurrentView}"
                           ContentTemplateSelector="{StaticResource ViewTemplateSelector}"/>
        </Border>
    </DockPanel>
</Window>
